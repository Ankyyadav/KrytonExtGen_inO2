# Geant4 configuration for 83mKr TPC calibration simulation
# Replaces the default O2 g4config.in (set via G4.configMacroFile in configKeyValues)
#
# Key physics decisions:
#
# 1. /mcPhysics/rangeCuts 0.0001 mm  (= 0.1 µm)
#    Secondary-electron production threshold passed to Geant4.
#
#    NOTE: TG4RegionsManager2 runs in energy-cut mode. The worker log shows:
#      "setRangePrecision has no effect when production cuts are set by energy"
#    This means TG4RegionsManager2 overrides rangeCuts for named regions with
#    energy values loaded from simcuts.dat (via VMC Gstpar calls).
#
#    The actual 1 keV threshold for TPC drift gas mediums comes from
#    Detector.cxx::SetSpecialPhysicsCuts(), which calls matmgr.SpecialCut with
#    1e-6 GeV (1 keV) BEFORE the base class reads simcuts.dat. TG4GeometryManager
#    honours the first Gstpar value set for each (medium, parameter) pair, so our
#    1 keV wins and simcuts.dat's 10 keV is ignored for those mediums.
#
#    rangeCuts is still set here because it empirically improves resolution by
#    ~0.9% (12.7% → 11.8%) when going from 0.1 mm to 0.0001 mm. The mechanism
#    is likely via the Penelope restricted-DEDX table used for delta-ray production
#    in regions not covered by TG4RegionsManager2's per-medium overrides.
#
#    All Kr-83m decay electrons are correctly tracked:
#      L-Auger  1.921 keV  → CUTELE=1 keV from SetSpecialPhysicsCuts ✓
#      T2-CE    7.475 keV  → tracked ✓
#      K-Auger 10.484 keV  → tracked ✓
#      L-CE T1 30.230 keV  → tracked ✓
#
# 2. /process/em/deexcitationIgnoreCut true
#    Auger electrons and fluorescence photons from atomic de-excitation are tracked
#    even when their energy is below the production cut. Needed for Kr Kα (12.6 keV)
#    and Auger cascades to appear as separate hits.
#
# 3. /process/eLoss/StepFunction 0.2 0.1 mm
#    Limits each step to 20% of the remaining kinetic energy (dRoverR=0.2) with
#    fine steps enforced below finalRange=0.1 mm. Produces many more, finer
#    ionisation steps than the default 1.0/1mm — improves 41.6 keV resolution
#    from ~10.4% to ~8.0%, essentially reaching G4 standalone parity (7.95%).
#
# 4. Optical process commands REMOVED:
#    FTFP_BERT_LIV does not register optical physics. The previous commands
#    (/process/optical/processActivation ...) triggered "COMMAND NOT FOUND"
#    errors that caused a "Batch is interrupted!!" state, silently skipping ALL
#    subsequent commands (transportationWithMsc Disabled, skipUnknownParticles,
#    looper thresholds). Removing them restores correct command execution.

/control/verbose 0
/mcVerbose/all 1
/mcTracking/loopVerbose 1
/mcTracking/skipNeutrino true

# Zero magnetic field (confirmed by --field 0 in o2-sim command)
/mcDet/setIsZeroMagField true
/mcMagField/setConstDistance 1 mm
/mcMagField/stepperType NystromRK4
/mcMagField/setDeltaIntersection  1.0e-05 mm
/mcMagField/setMinimumEpsilonStep 0.5e-05
/mcMagField/setMaximumEpsilonStep 1.0e-05

# Couple G4 random seed to ROOT gRandom
/mcControl/useRootRandom true

# Secondary production threshold: 0.1 mm. See comment block at top.
# Effective threshold in TPC gas is set to 1 keV by SetSpecialPhysicsCuts override.
/mcPhysics/rangeCuts 0.0001 mm
/mcRegions/setRangePrecision 5

# Atomic de-excitation: Auger electrons + fluorescence photons
# These are essential for correct Kr decay products (Kα at 12.6 keV, Auger cascades).
# DeexcitationIgnoreCut ensures they are tracked even below the production cut.
/process/em/fluo true
/process/em/fluoBearden true
/process/em/auger true
/process/em/augerCascade true
/process/em/deexcitationIgnoreCut true

# Step function for electrons and positrons
# dRoverR=0.2 limits each step to 20% energy loss; finalRange=0.1mm enforces fine
# steps in the last 0.1mm of range. Produces many more steps per track (~307 MB
# hits vs 188 MB for 1.0/1mm) — key driver of improved energy resolution.
/process/eLoss/StepFunction 0.2 0.1 mm

# Combined transportation + MSc mode is broken for ALICE (Geant 10.2.0+)
# IMPORTANT: this command was previously being SKIPPED due to the optical
# process batch interruption. It is now correctly applied.
/process/em/transportationWithMsc Disabled

# Allow generator to place particles with unknown PDG codes without crashing
/mcPrimaryGenerator/skipUnknownParticles true

# Looping particle thresholds (prevents stuck tracks)
# IMPORTANT: these were previously SKIPPED due to the optical process batch
# interruption. They are now correctly applied.
/mcPhysics/useHighLooperThresholds
/mcRun/setLooperThresholdImportantEnergy 100. MeV
